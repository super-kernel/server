{
    "name": "super-kernel/server",
    "description": "The server component for super-kernel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "swoole",
        "super-kernel",
        "server"
    ],
    "homepage": "https://github.com/super-kernel/server",
    "support": {
        "issues": "https://github.com/super-kernel/server/issues",
        "source": "https://github.com/super-kernel/server"
    },
    "autoload": {
        "psr-4": {
            "SuperKernel\\Server\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperKernelTest\\Server\\": "tests/"
        }
    },
    "config": {
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-swoole": "~6.0.0",
        "super-kernel/command": "~1.0.0"
    },
    "require-dev": {
        "super-kernel/bootstrap": "~1.0.0",
        "super-kernel/config": "^1.0",
        "super-kernel/event-dispatcher": "^1.0",
        "super-kernel/framework": "~1.0.0",
        "swoole/ide-helper": "~6.0.0"
    }
}
